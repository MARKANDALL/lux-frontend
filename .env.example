# ==============================================================================
# .env.example — Lux Pronunciation Tool
# ------------------------------------------------------------------------------
# Template for local environment variables. Copy this file to `.env` (or
# `.env.local`) and fill in real values. Never commit secrets — `.env*` is
# gitignored (see .gitignore) with `.env.example` as the sole exception.
#
# Variables prefixed `VITE_` are inlined into the client bundle at build time
# and are PUBLIC once shipped. Unprefixed vars stay server-side (dev proxy,
# Node scripts under tools/).
#
# Generated by scanning: process.env.* in *.js/*.mjs, import.meta.env.* in
# *.js/*.html, and vite.config.js. Grouped by service.
# ==============================================================================


# ------------------------------------------------------------------------------
# Supabase (client)
# Referenced in: src/supabase.js
# Also present (names only) in committed .env — values NOT copied.
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ------------------------------------------------------------------------------
# Lux API (backend origin)
# Referenced in: _api/util.js, vite.config.js
# Dev proxy target + client-side API base. Defaults to the production backend
# when unset (see vite.config.js:14 and _api/util.js:4).
# ------------------------------------------------------------------------------
# Used by vite.config.js for the /api dev proxy target
LUX_API_ORIGIN=https://luxury-language-api.vercel.app
VITE_LUX_API_ORIGIN=https://luxury-language-api.vercel.app
# Used by _api/util.js at runtime; leave blank in dev to hit the Vite proxy
VITE_API_BASE=


# ------------------------------------------------------------------------------
# Admin Auth (x-admin-token header)
# Referenced in: _api/util.js, vite.config.js
# vite.config.js checks these four names in order (first non-empty wins).
# Only VITE_ADMIN_TOKEN is read by the client bundle (_api/util.js:97).
# ------------------------------------------------------------------------------
VITE_ADMIN_TOKEN=your-admin-token-here
VITE_LUX_ADMIN_TOKEN=your-admin-token-here
LUX_ADMIN_TOKEN=your-admin-token-here
ADMIN_TOKEN=your-admin-token-here


# ------------------------------------------------------------------------------
# OpenAI Realtime Proxy (dev-only Node server)
# Referenced in: tools/dev-realtime-proxy.mjs
# Required to run `node tools/dev-realtime-proxy.mjs`. Not shipped to clients.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
PORT=8787
