# ─────────────────────────────────────────────────────────────────────────────
# Lux Pronunciation Tool — example environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in real values locally.
# Vite loads `.env`, `.env.local`, and `.env.[mode]` at dev/build time.
# Only variables prefixed with `VITE_` are exposed to the browser bundle;
# everything else is read by Node-side tooling (vite.config.js, tools/*.mjs).
#
# RULES
#  - NEVER commit real secrets. Placeholders like "your-xxx-here" are fine.
#  - Grouped by service/category (not alphabetical).
#  - Production secrets live in Vercel, not on developer machines.
#
# NOTE: `.env` and `.env.development.local` already exist in this repo — real
# values are NOT duplicated here. If you copy this file, drop your own values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ────────────────────────────────────────────────────────────────
# Referenced by: src/supabase.js
# Used for auth + Postgres client in the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ── Lux Backend API (Vercel-hosted) ─────────────────────────────────────────
# Referenced by: vite.config.js (dev proxy target), _api/util.js (fetch base)
# The Vite dev server proxies `/api/*` to API_ORIGIN. In prod, the frontend
# defaults to https://luxury-language-api.vercel.app if VITE_API_BASE is unset.
LUX_API_ORIGIN=https://luxury-language-api.vercel.app
VITE_LUX_API_ORIGIN=https://luxury-language-api.vercel.app
# Optional override for the browser-side fetch base (e.g. point at a local
# realtime proxy: http://localhost:8787). Leave blank to use the Vite proxy.
VITE_API_BASE=


# ── Admin Token (admin-gated API routes) ────────────────────────────────────
# Referenced by: vite.config.js (dev proxy header injection), _api/util.js
# (VITE_ADMIN_TOKEN used as build-time fallback for apiFetch x-admin-token).
# Any ONE of these may be set; vite.config.js checks them in this order.
# Only VITE_ADMIN_TOKEN is readable in the browser bundle.
VITE_ADMIN_TOKEN=your-admin-token-here
VITE_LUX_ADMIN_TOKEN=your-admin-token-here
LUX_ADMIN_TOKEN=your-admin-token-here
ADMIN_TOKEN=your-admin-token-here


# ── OpenAI Realtime (local dev proxy only) ──────────────────────────────────
# Referenced by: tools/dev-realtime-proxy.mjs
# Run `node tools/dev-realtime-proxy.mjs` to spike WebRTC SDP exchange locally.
# In production, the hosted API (luxury-language-api) owns these secrets.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin


# ── Dev Tooling ─────────────────────────────────────────────────────────────
# Referenced by: tools/dev-realtime-proxy.mjs (server port, default 8787).
PORT=8787
